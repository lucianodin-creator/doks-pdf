* { box-sizing: border-box; -webkit-tap-highlight-color: transparent; margin: 0; padding: 0; }
body { font-family: sans-serif; background: #111; height: 100dvh; width: 100vw; display: flex; flex-direction: column; overflow: hidden; }

/* BARRA DE FERRAMENTAS: Altura fixa e Prioridade Máxima */
.bottom-bar { 
    position: fixed !important; 
    bottom: 0 !important; 
    left: 0; 
    width: 100%; 
    height: 70px !important; /* Trava de segurança */
    background: #000; 
    display: flex; 
    align-items: center; 
    z-index: 9999 !important; 
    border-top: 1px solid #333;
    overflow: hidden; 
}

.container { flex: 1; overflow: auto; display: flex; justify-content: center; padding-bottom: 80px; }
#pdf-wrapper { position: relative; background: #fff; transform-origin: top left; }

/* MODAL: DPI Aware */
#sig-modal { position: fixed; inset: 0; background: #fff; z-index: 10000; display: none; flex-direction: column; }
#sig-pad { flex: 1; width: 100%; touch-action: none; background: #fff; }

.modal-btns { height: 80px; display: flex; padding: 10px; gap: 8px; background: #eee; }
.modal-btns button { flex: 1; border: none; border-radius: 8px; color: white; font-weight: bold; font-size: 14px; }
#btn-clear { background: #d32f2f; }
#btn-confirm { background: #2e7d32; }
