<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MEUPDF PRO</title>
    <link rel="stylesheet" href="style.css">
    <script src="https://unpkg.com/pdf-lib/dist/pdf-lib.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/signature_pad@4.0.0/dist/signature_pad.umd.min.js"></script>
</head>
<body>
    <div class="header">
        <span>MEUPDF PRO</span>
        <label id="btn-upload" for="file-in">📂 Abrir</label>
        <input type="file" id="file-in" accept="application/pdf" style="display:none;">
    </div>

    <div class="container">
        <div id="pdf-wrapper">
            <canvas id="pdf-render"></canvas>
        </div>
    </div>

    <div class="side-controls">
        <button class="btn-zoom" onclick="adjustZoom(0.2)">+</button>
        <button class="btn-zoom" onclick="adjustZoom(-0.2)">-</button>
    </div>

    <div class="bottom-bar">
        <div class="nav-item">
            <button class="btn-nav" onclick="changePage(-1)">◀</button>
        </div>
        <div class="nav-item">
            <span class="page-info"><span id="page-num">0</span> / <span id="page-count">0</span></span>
        </div>
        <div class="nav-item">
            <button class="btn-nav" onclick="changePage(1)">▶</button>
        </div>
        <div class="nav-item">
            <button class="btn-nav" style="background:#673ab7;" onclick="openSigPad()">🖋️</button>
        </div>
        <div class="nav-item">
            <button class="btn-nav" style="background:#2e7d32;" id="btn-save-pdf">✔️</button>
        </div>
    </div>

    <div id="sig-modal">
        <canvas id="sig-pad"></canvas>
        <div class="modal-btns">
            <button id="btn-close" onclick="closeSigPad()">Sair</button>
            <button id="btn-clear">Limpar</button>
            <button id="btn-confirm" onclick="confirmSig()">Confirmar</button>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
